@model MiniAppMvc.Models.Product

<h2>Edit Product</h2>

<form method="post">
    <input type="hidden" name="Id" value="@Model.Id" />

    <div>
        <label>Name:</label>
        <input type="text" name="Name" value="@Model.Name" />
    </div>

    <div>
        <label>Price:</label>
        <input type="number" name="Price" value="@Model.Price" />
    </div>

    <button type="submit">Update Product</button>
</form>