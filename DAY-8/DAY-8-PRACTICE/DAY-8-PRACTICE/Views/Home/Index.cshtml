@model List<DAY_8_PRACTICE.Models.User>

@{
    ViewData["Title"] = "Home Page";
}
<h1>Users</h1>

<form asp-controller="Home" asp-action="Index" method="Post">
    <label asp-for="@(new DAY_8_PRACTICE.Models.User().Name)">Name</label>
    <input name="Name"/>

    <br/>
    <label asp-for="@(new DAY_8_PRACTICE.Models.User().Email)">Email</label>
    <input name="Email"/>

    <br/>

    <button type="submit">Add user</button>


    </form>
<hr />
<h2>all users</h2>

@foreach (var user in Model)
{
    <div>
        <p>Id:@user.Id</p>
        <p>Name:@user.Name</p>
        <p>Email:@user.Email</p>
        <hr />
    </div>
}
